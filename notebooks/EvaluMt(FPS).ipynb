      "source": [
        "# COMP6011_20908692\n",
        "# Eval Met - FPS\n",
        "import time\n",
        "\n",
        "start = time.time()\n",
        "\n",
        "# simulate processing\n",
        "for _ in range(100):\n",
        "    time.sleep(0.01)\n",
        "\n",
        "end = time.time()\n",
        "\n",
        "fps = 100/(end-start)\n",
        "print(\"FPS:\", fps)"
      ]
    }
